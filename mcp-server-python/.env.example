# Web Intelligence MCP Server (Python) Configuration

# Google Places API Key (Required for best results)
# Get your API key from: https://developers.google.com/maps/documentation/places/web-service/get-api-key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Use Legacy Places API instead of New Places API (Optional)
# Set to 'true' if you prefer the legacy API
USE_LEGACY_PLACES_API=false

# Enable Scraper Fallback (Optional)
# When API fails or no key is provided, try direct scraping
ENABLE_SCRAPER_FALLBACK=true

# Default Search Settings (Optional)
DEFAULT_SEARCH_RADIUS=5000
DEFAULT_MAX_RESULTS=20
